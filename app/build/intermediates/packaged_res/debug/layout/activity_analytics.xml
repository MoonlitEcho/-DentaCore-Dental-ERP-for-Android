<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg">
    <androidx.appcompat.widget.Toolbar android:id="@+id/toolbar"
        android:layout_width="match_parent" android:layout_height="?attr/actionBarSize"
        android:background="@color/surface" style="@style/AppToolbar"/>
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:padding="14dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">
            <!-- Stat Cards Row 1 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="12dp" android:weightSum="2">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@drawable/stat_card_bg" android:padding="16dp"
                    android:layout_marginEnd="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Total Patients" android:textSize="12sp" android:textColor="@color/text3"/>
                    <TextView android:id="@+id/tvTotalPatients"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="32sp" android:textStyle="bold"
                        android:textColor="@color/accent"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@drawable/stat_card_bg" android:padding="16dp"
                    android:layout_marginStart="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Total Collected" android:textSize="12sp" android:textColor="@color/text3"/>
                    <TextView android:id="@+id/tvTotalRevenue"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Rs.0" android:textSize="26sp" android:textStyle="bold"
                        android:textColor="@color/accent3"/>
                </LinearLayout>
            </LinearLayout>
            <!-- Stat Cards Row 2 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp" android:weightSum="2">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@drawable/stat_card_bg" android:padding="16dp"
                    android:layout_marginEnd="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Total Billed" android:textSize="12sp" android:textColor="@color/text3"/>
                    <TextView android:id="@+id/tvTotalBilled"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Rs.0" android:textSize="26sp" android:textStyle="bold"
                        android:textColor="@color/text"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@drawable/stat_card_bg" android:padding="16dp"
                    android:layout_marginStart="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Outstanding" android:textSize="12sp" android:textColor="@color/text3"/>
                    <TextView android:id="@+id/tvOutstanding"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Rs.0" android:textSize="26sp" android:textStyle="bold"
                        android:textColor="@color/warn"/>
                </LinearLayout>
            </LinearLayout>
            <!-- Revenue Bar Chart -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/card_bg"
                android:padding="14dp" android:layout_marginBottom="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📊  Monthly Revenue (Last 6 Months)" android:textSize="14sp"
                    android:textStyle="bold" android:textColor="@color/accent"
                    android:layout_marginBottom="12dp"/>
                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/barChart"
                    android:layout_width="match_parent" android:layout_height="220dp"/>
            </LinearLayout>
            <!-- Procedure Pie Chart -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/card_bg"
                android:padding="14dp" android:layout_marginBottom="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🥧  Procedures Breakdown" android:textSize="14sp"
                    android:textStyle="bold" android:textColor="@color/accent"
                    android:layout_marginBottom="12dp"/>
                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/pieChart"
                    android:layout_width="match_parent" android:layout_height="260dp"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
