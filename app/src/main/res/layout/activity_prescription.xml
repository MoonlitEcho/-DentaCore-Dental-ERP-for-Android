<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg">
    <androidx.appcompat.widget.Toolbar android:id="@+id/toolbar"
        android:layout_width="match_parent" android:layout_height="?attr/actionBarSize"
        android:background="@color/surface" style="@style/AppToolbar"/>
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:padding="14dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">
            <!-- Clinic & Doctor -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/card_bg"
                android:padding="14dp" android:layout_marginBottom="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🏥  Clinic Details" android:textSize="14sp"
                    android:textStyle="bold" android:textColor="@color/accent" android:layout_marginBottom="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Doctor Name" android:textSize="12sp" android:textColor="@color/text2"
                    android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etDoctorName" android:layout_width="match_parent"
                    android:layout_height="48dp" android:background="@drawable/input_bg"
                    android:paddingHorizontal="14dp" android:textColor="@color/text"
                    android:textColorHint="@color/text3" android:hint="Dr. Name"
                    android:layout_marginBottom="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Clinic Name" android:textSize="12sp" android:textColor="@color/text2"
                    android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etClinicName" android:layout_width="match_parent"
                    android:layout_height="48dp" android:background="@drawable/input_bg"
                    android:paddingHorizontal="14dp" android:textColor="@color/text"
                    android:textColorHint="@color/text3" android:hint="Clinic / Hospital Name"/>
            </LinearLayout>
            <!-- Diagnosis -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/card_bg"
                android:padding="14dp" android:layout_marginBottom="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🩺  Diagnosis &amp; Procedure" android:textSize="14sp"
                    android:textStyle="bold" android:textColor="@color/accent" android:layout_marginBottom="10dp"/>
                <EditText android:id="@+id/etDiagnosis" android:layout_width="match_parent"
                    android:layout_height="70dp" android:background="@drawable/input_bg"
                    android:paddingHorizontal="14dp" android:paddingTop="12dp"
                    android:textColor="@color/text" android:textColorHint="@color/text3"
                    android:hint="Enter diagnosis" android:gravity="top"
                    android:inputType="textMultiLine" android:layout_marginBottom="10dp"/>
                <EditText android:id="@+id/etProcedure" android:layout_width="match_parent"
                    android:layout_height="48dp" android:background="@drawable/input_bg"
                    android:paddingHorizontal="14dp" android:textColor="@color/text"
                    android:textColorHint="@color/text3"
                    android:hint="Procedure (Extraction, Root Canal, Filling…)"/>
            </LinearLayout>
            <!-- Teeth -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/card_bg"
                android:padding="14dp" android:layout_marginBottom="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="🦷  Treated Teeth"
                        android:textSize="14sp" android:textStyle="bold" android:textColor="@color/accent2"/>
                    <Button android:id="@+id/btnSelectTeeth"
                        android:layout_width="wrap_content" android:layout_height="36dp"
                        android:text="Select" android:textColor="@color/accent2"
                        android:background="@null" android:textSize="13sp"/>
                </LinearLayout>
                <TextView android:id="@+id/tvTeethSelected"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="No teeth selected" android:textSize="13sp"
                    android:textColor="@color/text3" android:layout_marginTop="6dp"/>
            </LinearLayout>
            <!-- Medications -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/card_bg"
                android:padding="14dp" android:layout_marginBottom="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="💊  Medications"
                        android:textSize="14sp" android:textStyle="bold" android:textColor="@color/accent3"/>
                    <Button android:id="@+id/btnAddMedication"
                        android:layout_width="wrap_content" android:layout_height="36dp"
                        android:text="+ Add" android:textColor="@color/bg"
                        android:background="@drawable/btn_accent" android:textSize="12sp"
                        android:paddingHorizontal="14dp"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/llMedications"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </LinearLayout>
            <!-- Notes -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/card_bg"
                android:padding="14dp" android:layout_marginBottom="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📝  Notes / Instructions" android:textSize="14sp"
                    android:textStyle="bold" android:textColor="@color/accent" android:layout_marginBottom="10dp"/>
                <EditText android:id="@+id/etNotes" android:layout_width="match_parent"
                    android:layout_height="80dp" android:background="@drawable/input_bg"
                    android:paddingHorizontal="14dp" android:paddingTop="12dp"
                    android:textColor="@color/text" android:textColorHint="@color/text3"
                    android:hint="Patient instructions, follow-up notes…"
                    android:gravity="top" android:inputType="textMultiLine"/>
            </LinearLayout>
            <!-- Billing -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/card_bg"
                android:padding="14dp" android:layout_marginBottom="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="💰  Billing" android:textSize="14sp"
                    android:textStyle="bold" android:textColor="@color/accent3" android:layout_marginBottom="10dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="10dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Total Amount (Rs.)" android:textSize="12sp"
                            android:textColor="@color/text2" android:layout_marginBottom="4dp"/>
                        <EditText android:id="@+id/etBillAmount" android:layout_width="match_parent"
                            android:layout_height="48dp" android:background="@drawable/input_bg"
                            android:paddingHorizontal="14dp" android:textColor="@color/text"
                            android:textColorHint="@color/text3" android:hint="0"
                            android:inputType="numberDecimal"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Amount Paid (Rs.)" android:textSize="12sp"
                            android:textColor="@color/text2" android:layout_marginBottom="4dp"/>
                        <EditText android:id="@+id/etPaidAmount" android:layout_width="match_parent"
                            android:layout_height="48dp" android:background="@drawable/input_bg"
                            android:paddingHorizontal="14dp" android:textColor="@color/text"
                            android:textColorHint="@color/text3" android:hint="0"
                            android:inputType="numberDecimal"/>
                    </LinearLayout>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Payment Mode" android:textSize="12sp" android:textColor="@color/text2"
                    android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spPaymentMode" android:layout_width="match_parent"
                    android:layout_height="48dp" android:background="@drawable/input_bg"
                    android:paddingHorizontal="10dp" android:spinnerMode="dropdown"
                    android:popupBackground="@color/surface2"/>
            </LinearLayout>
            <!-- Action Buttons -->
            <Button android:id="@+id/btnSavePrescription"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:text="💾  Save Prescription" android:textColor="@color/bg"
                android:textStyle="bold" android:textSize="15sp"
                android:background="@drawable/btn_accent" android:layout_marginBottom="10dp"/>
            <Button android:id="@+id/btnDownloadPdf"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:text="📄  Download / Share PDF" android:textColor="@color/accent"
                android:textStyle="bold" android:textSize="15sp"
                android:background="@drawable/btn_outline" android:layout_marginBottom="20dp"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
